PORT=3000
# HOST: por defecto 127.0.0.1 (solo localhost, el puerto de Node nunca se
# expone directo a internet). Poner en 0.0.0.0 solo si sabes lo que haces
# (ej. probar desde otro dispositivo en la misma red local sin proxy).
HOST=127.0.0.1
API_KEY=CAMBIAR_POR_CLAVE_GENERADA
JWT_SECRET=CAMBIAR_POR_SECRET_GENERADO
# Firma HMAC del webhook interno bot -> servidor (anti-replay, ventana 5 min).
# Sin este valor el webhook rechaza TODAS las requests con 401.
WEBHOOK_SECRET=CAMBIAR_POR_SECRET_GENERADO
NGROK_DOMAIN=tu-dominio.ngrok-free.app
# Dominio propio opcional para CORS (respaldo -- lo normal es configurarlo
# desde la pestaña Configuracion del dashboard, tabla `settings`, sin
# necesidad de tocar este archivo ni reiniciar el servidor).
SERVER_DOMAIN=
OLLAMA_MODEL=llama3.2:1b
WORKER_PIN=1234
# Passwords iniciales de cuentas seed (opcional). Si no se define, se genera
# una al azar y se imprime una sola vez en el log al arrancar por primera vez.
SEED_PASSWORD_JESUS=
SEED_PASSWORD_JOHANA=
SEED_PASSWORD_FELIPE=
SEED_PASSWORD_FABIAN=
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
# Dias que se conservan los pedidos entregados en la DB antes de borrarlos
# (ya quedan respaldados en el PDF diario). Default: 90
ORDER_RETENTION_DAYS=90

# ─── Bot WhatsApp (Baileys) ────────────────────────────────────────────────
# Por defecto el bot arranca si hay un teléfono configurado en bot_config.
# Poner BOT_ENABLED=false para desactivar el arranque automático (sigue
# estando disponible la API para configurarlo manualmente).
BOT_ENABLED=true
# Clave para encriptar el teléfono de la empresa en la base de datos. Si no
# se define, se deriva de JWT_SECRET. RECOMENDADO: definir un valor aleatorio
# de 32+ caracteres y no cambiarlo una vez en producción (cambiarlo invalida
# el teléfono encriptado almacenado, obligando a reconfigurarlo).
BOT_ENCRYPTION_KEY=
# Límite anti-baneo de WhatsApp: máximos mensajes salientes por hora.
BOT_MAX_MSGS_PER_HOUR=200
# Reintentos de reconexión antes de rendirse (requiere reinicio manual).
BOT_MAX_RECONNECT_ATTEMPTS=10
# Días que se conservan los archivos de media descargados.
BOT_MEDIA_RETENTION_DAYS=30
# Líneas de log en memoria (buffer circular para /api/bot/logs).
LOG_BUFFER_LINES=500
