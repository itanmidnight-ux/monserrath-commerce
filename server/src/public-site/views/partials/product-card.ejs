<a class="product-card" href="/producto/<%= p.id %>">
  <div class="product-thumb" style="background: <%= p.meta.color %>;">
    <% if (p.images && p.images.length) { %>
      <img src="/img/producto/<%= p.images[0] %>" alt="<%= p.name %>" loading="lazy">
    <% } else { %>
      <span><%= p.meta.emoji %></span>
    <% } %>
  </div>
  <div class="product-info">
    <p class="cat"><%= p.category || 'Otros' %></p>
    <p class="name"><%= p.name %><% if (!p.in_stock) { %><span class="badge-agotado">Agotado</span><% } %></p>
    <p class="price">$<%= Number(p.price).toLocaleString('es-CO') %></p>
  </div>
</a>
